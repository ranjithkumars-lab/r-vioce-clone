FROM nvidia/cuda:12.4.1-devel-ubuntu22.04

# Prevent interactive prompts during apt installations (like tzdata)
ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies (Git, Python, Curl, Audio libraries)
RUN apt-get update && apt-get install -y \
    git \
    curl \
    python3 \
    python3-pip \
    python3-venv \
    ffmpeg \
    libsndfile1 \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js (v20)
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# Clone the repository
RUN git clone https://github.com/ranjithkumars-lab/r-vioce-clone.git .

# Ensure the start script is executable
RUN chmod +x start.sh

# Expose the API and Frontend ports so they map to 11333 and 11222
EXPOSE 8000
EXPOSE 5173

# Start the all-in-one script
CMD ["./start.sh"]
