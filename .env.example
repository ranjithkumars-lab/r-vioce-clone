# Voice Studio Environment Configuration

APP_NAME="Voice Studio"
APP_ENV="development"
DEBUG=true
API_V1_STR="/api/v1"

# Host & Port Settings
HOST="0.0.0.0"
PORT=8000

# Storage & Database Settings
STORAGE_DIR="storage"
DATABASE_URL="sqlite:///./storage/voice_studio.db"

# GPU Settings
CUDA_VISIBLE_DEVICES="0"
DEFAULT_GPU_INDEX=0

# Audio Processing Settings
MAX_UPLOAD_SIZE_MB=50
MIN_VOICE_DURATION_SEC=3.0
MAX_VOICE_DURATION_SEC=600.0
DEFAULT_SAMPLE_RATE=24000

# Logging
LOG_LEVEL="INFO"
LOG_DIR="logs"
