# Voice Studio Development Environment
APP_ENV=development
APP_NAME="Voice Studio (Dev)"
API_V1_STR=/api/v1
LOG_LEVEL=debug
LOG_DIR=storage/logs
STORAGE_DIR=storage

# Database & Queue
DB_URL=sqlite:///./storage/voice_studio.db
QUEUE_BACKEND=sqlite

# Scheduling & Workers
SCHEDULER_POLICY=first_available
WORKER_CONCURRENCY=1
GPU_RESERVATION_BUFFER_MB=500
DEFAULT_GPU_INDEX=0
