# Voice Studio Production Environment
APP_ENV=production
APP_NAME="Voice Studio"
API_V1_STR=/api/v1
LOG_LEVEL=info
LOG_DIR=/app/storage/logs
STORAGE_DIR=/app/storage

# Database & Queue
DB_URL=sqlite:////app/storage/voice_studio.db
# Uncomment to use Redis in cluster setups
# QUEUE_BACKEND=redis
# REDIS_URL=redis://redis:6379/0

# Scheduling & Workers
SCHEDULER_POLICY=least_vram_used
WORKER_CONCURRENCY=4
GPU_RESERVATION_BUFFER_MB=1024
DEFAULT_GPU_INDEX=0
